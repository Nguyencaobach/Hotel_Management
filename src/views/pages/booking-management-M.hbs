<div id="booking-management-module" class="dashboard-module" style="display: none;">

    <div id="bm-step1-types">
        <div class="row g-4 mt-2" id="bm-types-grid">
        </div>
    </div>

    <div id="bm-step2-rooms" style="display: none;">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <button class="btn btn-outline-secondary fw-bold" onclick="BookingManager.goBack()">
                <i class="fa-solid fa-arrow-left me-2"></i>Quay lại
            </button>
            <h4 class="mb-0 fw-bold text-dark" id="bm-selected-type-name">Danh sách phòng</h4>
        </div>

        <div class="row mb-4">
            <div class="col-md-5 col-lg-4">
                <div class="input-group shadow-sm">
                    <span class="input-group-text bg-white border-end-0 text-muted"><i
                            class="fa-solid fa-magnifying-glass"></i></span>
                    <input type="text" class="form-control border-start-0 ps-0" id="bmSearchRoom"
                        placeholder="Nhập số phòng để tìm kiếm...">
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Phòng / Tầng</th>
                                <th>Loại phòng</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="bmRoomTableBody">
                            <tr>
                                <td colspan="4" class="text-center text-muted py-3">Đang tải dữ liệu...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>

    <div class="modal fade" id="reservationListModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-primary border-0">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <i class="fa-solid fa-calendar-days me-2"></i>Danh sách đặt phòng trước - Phòng:
                        <span id="resListRoomNumber" class="text-white fs-4 ms-2"></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0 fw-bold text-secondary">Các phiên đặt trước sắp tới</h6>
                        <div>
                            <button class="btn fw-bold text-white me-2" style="background-color: #17a2b8; border: none;" onclick="BookingManager.scanQRCode()">
                                <i class="fa-solid fa-qrcode me-2"></i>Quét QR
                            </button>
                            <button class="btn fw-bold text-white" style="background-color: #4CAF50; border: none;" onclick="BookingManager.openAddNewReservation()">
                                <i class="fa-solid fa-plus me-2"></i>Thêm Đặt Phòng
                            </button>
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle text-center mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Mã Đặt</th>
                                    <th>Khách hàng</th>
                                    <th>SĐT / Email</th>
                                    <th>Dự kiến Nhận</th>
                                    <th>Dự kiến Trả</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="reservationTableBody">
                                <tr>
                                    <td colspan="6" class="text-muted py-4">Đang tải dữ liệu...</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="reservationFormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">
                        <i class="fa-solid fa-calendar-plus me-2"></i>Đặt trước - Phòng <span id="resFormRoomNumber"
                            class="text-white"></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Close"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="resFormBookingId">

                    <h6 class="fw-bold text-secondary mb-3 border-bottom pb-2">1. Thông tin khách hàng</h6>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên khách hàng <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="resGuestName" placeholder="VD: Nguyễn Văn A">
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số điện thoại <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="resGuestPhone" placeholder="VD: 0988...">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" id="resGuestEmail"
                                placeholder="VD: email@gmail.com">
                        </div>
                    </div>

                    <h6 class="fw-bold text-secondary mb-3 mt-4 border-bottom pb-2">2. Thời gian lưu trú</h6>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Dự kiến Nhận phòng <span class="text-danger">*</span></label>
                        <input type="datetime-local" class="form-control" id="resExpectedCheckin">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Dự kiến Trả phòng <span class="text-danger">*</span></label>
                        <input type="datetime-local" class="form-control" id="resExpectedCheckout">
                    </div>
                </div>
                <div class="modal-footer bg-light">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary fw-bold" id="btnSaveReservation">
                        <i class="fa-solid fa-floppy-disk me-2"></i>Lưu thông tin
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="rentFormModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold"><i class="fa-solid fa-key me-2"></i><span id="rfTitle">Tạo Phiên
                            Thuê</span></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4 bg-light">
                    <input type="hidden" id="rfRoomId"><input type="hidden" id="rfTypeId">
                    <input type="hidden" id="rfRentType"><input type="hidden" id="rfBookingId">

                    <div class="row g-4">
                        <div class="col-lg-7">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-header bg-white fw-bold text-primary border-bottom py-3">
                                    <i class="fa-solid fa-user-pen me-2"></i>Thông tin khách hàng
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-md-12">
                                            <label class="fw-bold form-label small">Họ tên khách <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" id="rfName" class="form-control"
                                                placeholder="Tên khách hàng">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="fw-bold form-label small">Số điện thoại <span
                                                    class="text-danger">*</span></label>
                                            <input type="text" id="rfPhone" class="form-control"
                                                placeholder="Chỉ nhập số"
                                                oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="fw-bold form-label small">Email (Tùy chọn)</label>
                                            <input type="email" id="rfEmail" class="form-control"
                                                placeholder="Ví dụ: abc@gmail.com">
                                        </div>

                                        <div class="col-md-6 mt-4 text-center">
                                            <label class="fw-bold form-label small text-secondary">Ảnh CCCD (Mặt
                                                Trước)</label>
                                            <div class="border rounded bg-light p-2 mb-2 mx-auto position-relative"
                                                style="height: 120px; overflow: hidden;">
                                                <img id="rfCccdFrontPreview" src=""
                                                    class="w-100 h-100 object-fit-cover rounded"
                                                    onerror="this.style.display='none'"
                                                    onload="this.style.display='block'">
                                            </div>
                                            <input type="file" id="rfCccdFrontFile" class="form-control form-control-sm"
                                                accept="image/*" capture="environment">
                                        </div>
                                        <div class="col-md-6 mt-4 text-center">
                                            <label class="fw-bold form-label small text-secondary">Ảnh CCCD (Mặt
                                                Sau)</label>
                                            <div class="border rounded bg-light p-2 mb-2 mx-auto position-relative"
                                                style="height: 120px; overflow: hidden;">
                                                <img id="rfCccdBackPreview" src=""
                                                    class="w-100 h-100 object-fit-cover rounded"
                                                    onerror="this.style.display='none'"
                                                    onload="this.style.display='block'">
                                            </div>
                                            <input type="file" id="rfCccdBackFile" class="form-control form-control-sm"
                                                accept="image/*" capture="environment">
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-5">
                            <div class="card shadow-sm border-0 h-100">
                                <div class="card-header bg-white fw-bold text-success border-bottom py-3">
                                    <i class="fa-solid fa-bed me-2"></i>Chi tiết Thuê phòng
                                </div>
                                <div class="card-body bg-white">
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted fw-bold">Phòng đang chọn:</span>
                                        <span class="fs-4 fw-bold text-dark" id="rfRoomNumberDisplay"></span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                                        <span class="text-muted fw-bold">Hình thức thuê:</span>
                                        <span class="badge bg-danger fs-6" id="rfRentTypeDisplay"></span>
                                    </div>
                                    <div
                                        class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
                                        <span class="text-muted fw-bold">Giá phòng:</span>
                                        <span class="fs-5 fw-bold text-danger" id="rfPriceDisplay">0 đ</span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="fw-bold form-label text-success small">Giờ Check-in Thực
                                            tế</label>
                                        <input type="datetime-local" id="rfCheckIn"
                                            class="form-control border-success bg-light">
                                    </div>
                                    <div class="mb-3">
                                        <label class="fw-bold form-label text-danger small">Giờ Check-out Dự kiến (Không
                                            bắt buộc)</label>
                                        <input type="datetime-local" id="rfCheckOut" class="form-control border-danger">
                                        <small class="text-muted fst-italic">Nếu chưa rõ giờ trả, có thể để
                                            trống.</small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top">
                    <button type="button" class="btn btn-secondary fw-bold px-4" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary fw-bold px-4" id="btnSaveRent"><i
                            class="fa-solid fa-floppy-disk me-2"></i>Xác nhận Lưu</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="activeSessionModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg" style="background-color: #f4f6f9;">

                <div class="modal-header bg-primary border-0 rounded-top">
                    <h5 class="modal-title fw-bold text-white d-flex align-items-center">
                        <i class="fa-regular fa-clock fs-4 me-2"></i> Đang thuê phòng - 
                        <span class="text-white ms-2">Phòng: <span id="asRoomNumber"></span></span>
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="row g-4">

                        <div class="col-lg-5 d-flex flex-column gap-3">

                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-2 border-bottom pb-2">
                                        <h6 class="fw-bold text-secondary mb-0"><i class="fa-solid fa-user-clock me-2"></i>Thông tin lưu trú</h6>
                                        <button class="btn btn-sm btn-outline-warning py-0" onclick="BookingManager.editActiveSession()"><i class="fa-solid fa-pen"></i> Sửa</button>
                                    </div>
                                    
                                    <div class="row g-2 small">
                                        <div class="col-7 border-end pe-2">
                                            <div class="mb-1 text-truncate"><span class="text-muted">Khách: </span><span id="asName" class="fw-bold text-dark ms-1"></span></div>
                                            <div class="mb-1"><span class="text-muted">SĐT: </span><span id="asPhone" class="fw-bold text-dark ms-1"></span></div>
                                            <div class="text-truncate"><span class="text-muted">Email: </span><span id="asEmail" class="fw-bold text-dark ms-1"></span></div>
                                        </div>
                                        
                                        <div class="col-5 ps-3">
                                            <div class="mb-2">
                                                <div class="text-muted" style="font-size: 0.7rem;">Vào (Check-in)</div>
                                                <div id="asCheckIn" class="text-primary fw-bold" style="font-size: 0.8rem;"></div>
                                            </div>
                                            <div>
                                                <div class="text-muted" style="font-size: 0.7rem;">Dự kiến ra (Check-out)</div>
                                                <div id="asCheckOut" class="text-danger fw-bold" style="font-size: 0.8rem;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold text-secondary mb-2 small"><i
                                            class="fa-solid fa-id-card me-2"></i>Giấy tờ tùy thân</h6>
                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="bg-light rounded border d-flex align-items-center justify-content-center"
                                                style="height: 100px; overflow: hidden;">
                                                <img id="asCccdFrontImg" src="" class="w-100 h-100 object-fit-cover"
                                                    onerror="this.style.display='none'"
                                                    onload="this.style.display='block'">
                                            </div>
                                            <div class="text-center text-muted" style="font-size: 0.75rem;">Mặt trước
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="bg-light rounded border d-flex align-items-center justify-content-center"
                                                style="height: 100px; overflow: hidden;">
                                                <img id="asCccdBackImg" src="" class="w-100 h-100 object-fit-cover"
                                                    onerror="this.style.display='none'"
                                                    onload="this.style.display='block'">
                                            </div>
                                            <div class="text-center text-muted" style="font-size: 0.75rem;">Mặt sau
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 border-top border-success border-3">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold text-success mb-3"><i class="fa-solid fa-cart-plus me-2"></i>Gọi
                                        thêm Dịch vụ / Món ăn</h6>

                                    <ul class="nav nav-pills mb-3 gap-2" style="font-size: 0.85rem;">
                                        <li class="nav-item flex-fill text-center">
                                            <button class="nav-link service-tab-btn active fw-bold w-100 border"
                                                data-type="INVENTORY"
                                                onclick="BookingManager.switchServiceTab('INVENTORY')">
                                                <i class="fa-solid fa-box me-1"></i>Kho (Minibar)
                                            </button>
                                        </li>
                                        <li class="nav-item flex-fill text-center">
                                            <button class="nav-link service-tab-btn fw-bold w-100 border"
                                                data-type="SERVICE"
                                                onclick="BookingManager.switchServiceTab('SERVICE')">
                                                <i class="fa-solid fa-concierge-bell me-1"></i>Dịch vụ khác
                                            </button>
                                        </li>
                                    </ul>

                                    <div class="mb-2" id="svcCategoryContainer">
                                        <label class="form-label fw-bold text-secondary small mb-1">Danh mục</label>
                                        <select id="svcCategory" class="form-select form-select-sm border-primary"
                                            onchange="BookingManager.loadServiceData()">
                                            <option value="">-- Tất cả --</option>
                                        </select>
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label fw-bold text-secondary small mb-1">Tên món <span
                                                class="text-danger">*</span></label>
                                        <select id="svcItem" class="form-select form-select-sm border-success"
                                            onchange="BookingManager.changeServiceItem()">
                                            <option value="">-- Vui lòng chọn --</option>
                                        </select>
                                    </div>

                                    <div class="row g-2 mb-3">
                                        <div class="col-4">
                                            <label class="form-label fw-bold text-secondary small mb-1">S.L</label>
                                            <input type="number" id="svcQty" class="form-control form-control-sm" value="1" min="1" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                                        </div>
                                        <div class="col-8">
                                            <label class="form-label fw-bold text-secondary small mb-1">Đơn giá</label>
                                            <input type="text" id="svcPriceDisplay"
                                                class="form-control form-control-sm bg-white text-danger fw-bold"
                                                readonly placeholder="0 đ">
                                            <input type="hidden" id="svcRawPrice">
                                        </div>
                                    </div>

                                    <button type="button" class="btn btn-success btn-sm fw-bold w-100 shadow-sm"
                                        onclick="BookingManager.submitAddService()">
                                        <i class="fa-solid fa-plus me-2"></i>Thêm vào Hóa đơn
                                    </button>
                                </div>
                            </div>

                        </div>

                        <div class="col-lg-7 d-flex flex-column gap-3">

                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="text-muted small fw-bold">Thời gian lưu trú:</div>
                                        <div class="fw-bold text-primary font-monospace" id="asTimer"
                                            style="font-size: 2rem; line-height: 1.2;">00:00:00</div>
                                    </div>
                                    <div class="text-end">
                                        <div class="badge bg-danger mb-1" id="asRentType"></div>
                                        <div class="text-muted small fw-bold">Đơn giá: <span class="text-dark fs-6"
                                                id="asUnitPrice"></span></div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 flex-grow-1 d-flex flex-column"
                                style="height: 300px;">
                                <div class="card-header bg-white py-2 border-bottom">
                                    <h6 class="fw-bold text-secondary mb-0"><i
                                            class="fa-solid fa-receipt me-2 text-warning"></i>Chi tiết Dịch vụ đã gọi
                                    </h6>
                                </div>

                                <div class="card-body p-0 custom-scrollbar" style="overflow-y: auto;">
                                    <table class="table table-sm table-hover align-middle text-center mb-0">
                                        <thead class="table-light sticky-top shadow-sm" style="z-index: 1;">
                                            <tr>
                                                <th class="text-start ps-3">Tên dịch vụ</th>
                                                <th>SL</th>
                                                <th>Đơn giá</th>
                                                <th class="text-end">Thành tiền</th>
                                                <th></th>
                                            </tr>
                                        </thead>
                                        <tbody id="asServiceList">
                                            <tr>
                                                <td colspan="5" class="text-muted py-4 fst-italic">Chưa sử dụng dịch vụ
                                                    nào.</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <div class="card-footer bg-light text-end py-2">
                                    <span class="text-muted fw-bold small">Tổng tiền dịch vụ:</span>
                                    <span class="text-danger fw-bold ms-2 fs-6" id="asTotalServices">0 đ</span>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-3 mt-auto">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-end mb-3">
                                        <span class="text-secondary fw-bold fs-5">TIỀN PHÒNG THỰC TRẢ <br><small
                                                class="text-muted fw-normal fs-6">(Tính theo phút)</small></span>
                                        <span class="fw-bold text-danger" id="asTotalMoney"
                                            style="font-size: 2.2rem; line-height: 1;">0 đ</span>
                                    </div>
                                        <button id="btnOpenCheckout" class="btn btn-danger w-100 py-3 fw-bold fs-5 rounded-3 shadow-sm" onclick="BookingManager.openCheckoutModal()">
                                            <i class="fa-solid fa-check-circle me-2"></i> THANH TOÁN / CHECKOUT
                                        </button>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-xl" style="max-width: 1100px;">
            <div class="modal-content border-0 shadow-lg" style="background-color: #f8f9fa;">
                
                <div class="modal-header border-0" style="background-color: #0d6efd;">
                    <h4 class="modal-title fw-bold text-white mb-0">Hóa đơn tạm tính - Phòng <span id="coModalRoomNumber"></span></h4>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="row g-4">
                        
                        <div class="col-lg-5 d-flex flex-column gap-3">
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3">
                                    <h6 class="fw-bold text-secondary mb-3"><i class="fa-solid fa-user me-2"></i>Thông tin lưu trú</h6>
                                    <div class="row g-2 small">
                                        <div class="col-6 border-end">
                                            <div class="mb-1"><span class="text-muted">Khách: </span><span id="coGuestName" class="fw-bold text-dark ms-1"></span></div>
                                            <div class="mb-1"><span class="text-muted">SĐT: </span><span id="coGuestPhone" class="fw-bold text-dark ms-1"></span></div>
                                            <div class="text-truncate"><span class="text-muted">Email: </span><span id="coGuestEmail" class="fw-bold text-dark ms-1"></span></div>
                                        </div>
                                        <div class="col-6 ps-3">
                                            <div class="mb-2">
                                                <div class="text-muted" style="font-size: 0.7rem;">Vào (Check-in)</div>
                                                <div id="coCheckIn" class="text-primary fw-bold" style="font-size: 0.8rem;"></div>
                                            </div>
                                            <div>
                                                <div class="text-muted" style="font-size: 0.7rem;">Dự kiến ra (Check-out)</div>
                                                <div id="coCheckOut" class="text-danger fw-bold" style="font-size: 0.8rem;"></div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card border-0 shadow-sm rounded-3">
                                <div class="card-body p-3">
                                    <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
                                        <div>
                                            <div class="text-muted small fw-bold">Thời gian lưu trú:</div>
                                            <div class="fw-bold text-primary fs-4" id="coTimeLabel"></div>
                                        </div>
                                        <div class="text-end">
                                            <div class="badge bg-danger mb-1" id="coRentType"></div>
                                            <div class="text-muted small fw-bold">Đơn giá: <span class="text-dark" id="coUnitPrice"></span></div>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-end mt-2">
                                        <span class="text-secondary fw-bold">TIỀN PHÒNG THỰC TRẢ <br><small class="text-muted fw-normal fs-6">(Tính theo phút)</small></span>
                                        <span class="fw-bold text-danger fs-3" id="coRoomMoneyLeft">0</span>
                                    </div>
                                </div>
                            </div>
                            <div class="card border-0 shadow-sm rounded-3 flex-grow-1 d-flex flex-column">
                                <div class="card-body p-0 custom-scrollbar" style="max-height: 250px; overflow-y: auto;">
                                    <table class="table table-sm align-middle mb-0">
                                        <thead class="table-light sticky-top" style="font-size: 0.85rem;">
                                            <tr>
                                                <th class="ps-3"><i class="fa-solid fa-receipt text-warning me-1"></i> Dịch vụ đã gọi</th>
                                                <th class="text-center">SL</th>
                                                <th class="text-end">Đơn giá</th>
                                                <th class="text-end pe-3">Thành tiền</th>
                                            </tr>
                                        </thead>
                                        <tbody id="coServiceList" class="small fw-bold text-dark"></tbody>
                                    </table>
                                </div>
                                <div class="card-footer bg-light text-end py-2">
                                    <span class="text-muted fw-bold small">Tổng tiền dịch vụ:</span>
                                    <span class="text-danger fw-bold ms-2 fs-6" id="coServiceMoneyLeft">0 đ</span>
                                </div>
                            </div>
                        </div>

                        <div class="col-lg-7 d-flex flex-column">
                            
                            <div class="row mb-3 fw-bold text-dark" style="font-size: 0.9rem;">
                                <div class="col-8 d-flex flex-column">
                                    <div class="d-flex mb-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Hóa đơn số:</span> <span id="coInvoiceNo" class="fw-normal text-break"></span></div>
                                    <div class="d-flex mb-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Ngày xuất:</span> <span id="coCheckoutDate" class="fw-normal text-break"></span></div>
                                    <div class="d-flex mb-2 mt-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Cơ sở kinh doanh:</span> <span id="coBusinessName" class="fw-bold text-primary text-break"></span></div>
                                    <div class="d-flex mb-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Mã số thuế:</span> <span id="coTaxCode" class="fw-normal text-break"></span></div>
                                    <div class="d-flex mb-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Địa chỉ:</span> <span id="coAddress" class="fw-normal text-break"></span></div>
                                    <div class="d-flex mb-2"><span class="text-muted flex-shrink-0" style="width: 140px;">Email liên hệ:</span> <span id="coEmail" class="fw-normal text-break"></span></div>
                                    <div class="d-flex mb-0"><span class="text-muted flex-shrink-0" style="width: 140px;">Hotline:</span> <span id="coPhone" class="fw-normal text-break"></span></div>
                                </div>
                                <div class="col-4 d-flex justify-content-end align-items-start">
                                    <div class="bg-dark rounded-4 d-flex justify-content-center align-items-center shadow-sm overflow-hidden" style="width: 120px; height: 120px; border: 2px solid #fff;">
                                        <img id="coLogo" src="" alt="Logo" style="width: 100%; height: 100%; object-fit: cover; display: none;">
                                        <span id="coLogoText" class="text-white fw-bold fs-6">Logo</span>
                                    </div>
                                </div>
                            </div>

                            <div class="card border-0 shadow-sm rounded-4 mt-auto">
                                <div class="card-body p-4">
                                    <div class="row align-items-center">
                                        
                                        <div class="col-md-6 border-end pe-4 d-flex flex-column justify-content-center">
                                            <div class="bg-light p-3 rounded-3 mb-3 border">
                                                <div class="d-flex justify-content-between align-items-center mb-2">
                                                    <span class="text-dark fw-bold small">TIỀN PHÒNG</span>
                                                    <span class="fw-bold text-danger fs-5" id="coRoomMoneyRight">0 đ</span>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center border-top pt-2 mt-2">
                                                    <span class="text-dark fw-bold small">TIỀN DỊCH VỤ</span>
                                                    <span class="fw-bold text-danger fs-5" id="coServiceMoneyRight">0 đ</span>
                                                </div>
                                            </div>
                                        </div> 

                                            <div class="col-md-6 ps-4">
                                                <div class="text-center text-muted fw-bold small mb-2">Chọn hình thức thanh toán</div>
                                                
                                                <style>
                                                    .custom-radio:checked + .custom-label {
                                                        border-color: #0d6efd !important;
                                                        background-color: #f0f7ff !important;
                                                    }
                                                    .custom-label {
                                                        border: 2px solid #dee2e6;
                                                        background-color: #fff;
                                                        cursor: pointer;
                                                        transition: 0.2s;
                                                    }
                                                </style>

                                                <div class="d-flex justify-content-center gap-3 w-100">
                                                    <input type="radio" class="btn-check custom-radio" name="paymentMethod" id="payBank" value="BANK_TRANSFER" checked 
                                                        onchange="document.getElementById('paymentText').innerText = 'Thanh toán bằng Chuyển khoản'; document.getElementById('btnShowQr').classList.remove('d-none')">
                                                    <label class="custom-label d-flex flex-column align-items-center justify-content-center rounded-3 w-50" for="payBank" style="height: 75px;">
                                                        <i class="fa-solid fa-building-columns fs-4 mb-1 text-primary"></i>
                                                        <span class="fw-bold text-dark" style="font-size: 0.8rem;">Chuyển khoản</span>
                                                    </label>
                                                    
                                                    <input type="radio" class="btn-check custom-radio" name="paymentMethod" id="payCash" value="CASH" 
                                                        onchange="document.getElementById('paymentText').innerText = 'Thanh toán bằng Tiền mặt'; document.getElementById('btnShowQr').classList.add('d-none')">
                                                    <label class="custom-label d-flex flex-column align-items-center justify-content-center rounded-3 w-50" for="payCash" style="height: 75px;">
                                                        <i class="fa-solid fa-money-bill-wave fs-4 mb-1 text-success"></i>
                                                        <span class="fw-bold text-dark" style="font-size: 0.8rem;">Tiền mặt</span>
                                                    </label>
                                                </div>

                                                <div class="text-center mt-3 d-flex flex-column align-items-center gap-2">
                                                    <span id="paymentText" class="badge bg-primary px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.85rem;">
                                                        Thanh toán bằng Chuyển khoản
                                                    </span>
                                                    <button id="btnShowQr" class="btn btn-sm btn-outline-primary fw-bold border-2 rounded-pill px-3" onclick="BookingManager.showVietQr()">
                                                        <i class="fa-solid fa-qrcode me-1"></i> Hiển thị mã QR
                                                    </button>
                                                </div>
                                            </div>

                                            <div class="modal fade" id="vietQrModal" tabindex="-1" aria-hidden="true" style="z-index: 1070;">
                                                <div class="modal-dialog modal-dialog-centered modal-sm">
                                                    <div class="modal-content border-0 shadow-lg text-center" style="border-radius: 1.5rem;">
                                                        <div class="modal-header border-0 pb-0">
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                        </div>
                                                        <div class="modal-body p-4 pt-0">
                                                            <h5 class="fw-bold text-dark mb-3">Quét mã để thanh toán</h5>
                                                            <div class="bg-white p-2 rounded-3 shadow-sm mb-3 border">
                                                                <img id="vietQrImg" src="" alt="VietQR" class="img-fluid rounded-2" style="min-height: 250px;">
                                                            </div>
                                                            <div class="small text-muted mb-3">
                                                                <div class="fw-bold text-primary" id="qrBankInfo"></div>
                                                                <div class="fw-bold text-dark" id="qrAccountInfo"></div>
                                                            </div>
                                                            <button type="button" class="btn btn-primary w-100 fw-bold rounded-pill py-2" data-bs-dismiss="modal">Đã quét xong</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                    </div>

                                    <div class="mt-4 pt-3 border-top border-2 border-danger border-opacity-25 d-flex justify-content-between align-items-center">
                                        <h4 class="fw-bold text-dark mb-0 text-uppercase">Tổng cộng</h4>
                                        <h2 class="fw-bold text-danger mb-0" id="coGrandTotal" style="font-size: 2rem;">0 đ</h2>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="text-end mt-4">
                                <button type="button" class="btn btn-secondary px-4 fw-bold py-2 me-2 shadow-sm rounded-3" data-bs-dismiss="modal">Trở lại</button>
                                <button type="button" class="btn btn-success px-5 fw-bold py-2 fs-5 shadow-sm rounded-3" onclick="BookingManager.confirmCheckout()">
                                    <i class="fa-solid fa-circle-check me-2"></i> Xác nhận Thanh toán
                                </button>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="checkoutStatusModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content border-0 shadow-lg text-center p-4" style="border-radius: 1rem;">
                <div id="csmIcon" class="mb-3 d-flex justify-content-center align-items-center">
                    </div>
                <h4 id="csmTitle" class="fw-bold mb-2">Thông báo</h4>
                <p id="csmMessage" class="text-muted small mb-4" style="font-size: 0.9rem;"></p>
                <div>
                    <button id="csmBtn" type="button" class="btn px-4 py-2 fw-bold shadow-sm rounded-pill w-100" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="confirmCheckoutModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" style="z-index: 1060;">
        <div class="modal-dialog modal-dialog-centered modal-sm" style="max-width: 320px;"> <div class="modal-content border-0 shadow-lg" style="border-radius: 1.5rem; background-color: #fff;">
                <div class="modal-body p-4 text-center">
                    
                    <div class="mb-3 d-flex justify-content-center align-items-center">
                        <div class="d-flex justify-content-center align-items-center border border-warning rounded-circle shadow-sm" style="width: 80px; height: 80px; border-width: 4px !important; background-color: #fdfae5;">
                            <i class="fa-solid fa-question text-warning" style="font-size: 3.5rem;"></i>
                        </div>
                    </div>

                    <h4 class="fw-bold mb-3 text-dark text-uppercase">Xác nhận thanh toán</h4>
                    
                    <p class="text-muted mb-4 px-2" style="font-size: 0.95rem; line-height: 1.5;">
                        Bạn có chắc chắn muốn xác nhận <br>thanh toán hóa đơn này <br> bằng <strong id="confirmPayMethodText" class="text-primary fs-6"></strong> không?
                    </p>
                    
                    <div class="d-flex flex-column align-items-center gap-2">
                        <button type="button" class="btn btn-warning fw-bold px-5 py-2 rounded-pill shadow w-100 text-dark" id="btnExecuteCheckout" onclick="BookingManager.executeCheckout()">
                            <i class="fa-solid fa-check me-1"></i> ĐỒNG Ý
                        </button>
                        
                        <button type="button" class="btn btn-link text-muted fw-bold p-0 mt-1" data-bs-dismiss="modal" style="text-decoration: none; font-size: 0.85rem;">
                            HỦY BỎ
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>

</div>


